# App
APP_ENV=development
LOG_LEVEL=INFO
LOG_JSON=true

# Web/API ports
WEB_PORT=5173
API_PORT=8000
VITE_API_BASE_URL=http://localhost:8000

# Database
POSTGRES_DB=content_factory
POSTGRES_USER=content_factory
POSTGRES_PASSWORD=content_factory_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://content_factory:content_factory_dev@localhost:5432/content_factory

# Feature flags
ENABLE_SCHEDULER=false

# Source API keys (fill later)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=content-factory/0.1
YOUTUBE_API_KEY=
PRODUCTHUNT_CLIENT_ID=
PRODUCTHUNT_CLIENT_SECRET=
